# ─────────────────────────────────────────────
# BotballDashboard – environment variables
# Copy to .env and fill in all values.
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
APP_ENV=production          # development | production
APP_SECRET_KEY=change-me-32-chars-minimum
APP_BASE_URL=https://botball.example.com
ALLOWED_ORIGINS=https://botball.example.com

# ── Database ─────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=botball
POSTGRES_USER=botball
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://botball:change-me@db:5432/botball

# ── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email (primary SMTP) ──────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=BotballDashboard <noreply@example.com>
SMTP_TLS=true

# ── Email fallback (SendGrid) ─────────────────
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@example.com

# ── Web Push ─────────────────────────────────
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_ADMIN_EMAIL=admin@example.com

# ── 3D Print ─────────────────────────────────
PRINTER_CREDENTIAL_ENCRYPTION_KEY=change-me-fernet-key

# ── File uploads ─────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Traefik / SSL (used in docker-compose.yml) ─
TRAEFIK_EMAIL=admin@example.com
DOMAIN=botball.example.com
