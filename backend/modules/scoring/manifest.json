  "nav_items": [
    { "label": { "de": "Rangliste",     "en": "Ranking"      }, "path": "/scoring/ranking",      "icon": "trophy",    "permission": "scoring:read"  },
    { "label": { "de": "Turnier",       "en": "Tournament"   }, "path": "/scoring/tournament",   "icon": "bracket",   "permission": "scoring:read"  },
    { "label": { "de": "Score-Sheets",  "en": "Score Sheets" }, "path": "/scoring/score-sheets", "icon": "document",  "permission": "scoring:admin" }
